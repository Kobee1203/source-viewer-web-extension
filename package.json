{
  "name": "source-viewer-web-extension",
  "version": "1.5.0",
  "description": "A browser extension to view formatted source code with syntax highlighting.",
  "type": "module",
  "scripts": {
    "postinstall": "wxt prepare",
    "prepare": "husky",
    "clean": "wxt clean && git clean -fXd -e \\!.idea -e \\!.idea/**/* -e \\!.vscode -e \\!.vscode/**/* -e \\!.claude -e \\!.claude/**/* -e \\!.agents -e \\!.agents/**/*",
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build && wxt build -b firefox",
    "zip": "wxt zip && wxt zip -b firefox",
    "compile": "vue-tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:css": "stylelint \"src/**/*.{css,vue}\"",
    "lint:css:fix": "stylelint \"src/**/*.{css,vue}\" --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "author": "Nicolas Dos Santos",
  "license": "ISC",
  "packageManager": "pnpm@11.4.0",
  "engines": {
    "node": ">=24",
    "pnpm": ">=11"
  },
  "dependencies": {
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@lucide/vue": "^1.24.0",
    "@uiw/codemirror-themes-all": "^4.25.11",
    "@wxt-dev/i18n": "^0.2.6",
    "codemirror": "^6.0.2",
    "js-beautify": "^1.15.4",
    "vue": "^3.5.39",
    "vue-codemirror6": "^1.6.1"
  },
  "devDependencies": {
    "@types/js-beautify": "^1.14.3",
    "@vue/eslint-config-typescript": "^14.9.0",
    "@wxt-dev/module-vue": "^1.0.3",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "postcss-html": "^1.8.1",
    "prettier": "^3.9.5",
    "stylelint": "^17.14.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-vue": "^1.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0",
    "vue-tsc": "^3.3.7",
    "wxt": "^0.20.27"
  }
}
